
@model List<Plan>



    
                <div class="row g-4">

                    @foreach (var plan in Model)
                    {
                        <div class="col-md-6">

                            <div class="card shadow-sm border-0 h-100">

                                <div class="card-header text-white text-center py-4 @(plan.IsActive ?"bg-primary-color" : "bg-secondary")">
                                    <h4 class="mb-0">@plan.Name</h4>
                                </div>

                                <div class="card-body">

                                    <div class="text-center mb-4">
                                        <div class="display-4 fw-bold text-primary-color">
                                            @plan.Price
                                        </div>

                                        <small class="text-muted">EGP</small>
                                    </div>

                                    <div class="mb-3">

                                        <p class="text-muted mb-2">
                                            <i class="bi bi-calendar-check text-primary-color me-2"></i>
                                            <strong>Duration:</strong> @plan.DurationDays
                                        </p>

                                        <p class="text-muted mb-3">
                                            <i class="bi bi-file-text text-primary-color me-2"></i>
                                            <strong>Description:</strong>
                                        </p>

                                        <p class="small">@plan.Description</p>

                                    </div>

                                    <div class="d-grid gap-2">

                                        <a href="/Plans/Details/@plan.Id"
                                           class="btn btn-outline-dark btn-sm">
                                            <i class="bi bi-eye me-1"></i>
                                            View Details
                                        </a>

                                        <div class="d-flex gap-2">

                                            <a href="/Plans/Edit/@plan.Id"
                                               class="btn btn-outline-dark btn-sm flex-fill">
                                                <i class="bi bi-pencil me-1"></i>
                                                Edit
                                            </a>

                                            <form href="\Plans\Activate\@plan.Id"
                                                  method="post"
                                                  class="flex-fill">
                                                  @*If Plan is Active put Class text-danger if not text-success*@
                                                <button type="submit"
                                                        class="btn btn-outline-dark btn-sm w-100 @(plan.IsActive ?"text-danger" : "text-success")" >

                                                    @if (plan.IsActive)
                                                    {
                                                        @* Display If No plan is inactive*@
                                                        <i class="bi bi-x-circle me-1"> Deactive</i>
                                                        
                                                    }
                                                    else
                                                    {
                                                            @* Display If No plan is Active*@
                                                            <i class="bi bi-check-circle me-1">Active</i>
                                                           
                                                        
                                                    }

                                                </button>

                                            </form>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>
                
                @if (Model is not null && Model.Any())
                {  @* Display This Div If  Plans Are Available *@
                    <div class="row g-4"></div>
                }else{
                @* Display This Div If No Plans Are Available *@
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No Plans Available</h4>
                </div>
                }
            </div>
        </main>
    </div>



